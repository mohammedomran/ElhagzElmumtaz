@page
@model LeagueDetailsModel
@{
    ViewData["Title"] = "تفاصيل الدوري — الحجز الممتاز";
}
  <div class="app-page">

    <header class="app-bar">
      <h1 class="app-bar__title">تفاصيل الدوري</h1>
      <a href="/leagues" class="app-bar__back">
        رجوع
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6" /></svg>
      </a>
    </header>

    <main class="app-content">

      <!-- League info -->
      <section class="glass-card" style="margin-bottom:var(--s-md)">
        <span class="pill pill--primary pill--dot" style="margin-bottom:var(--s-md)">دوري الجمعة</span>
        <h2 class="card-title" style="margin-bottom:var(--s-lg)">دوري الجمعة — الموسم الأول</h2>

        <div class="match-row">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"><rect x="3" y="4.5" width="18" height="16" rx="2"/><path d="M3 9h18M8 3v3M16 3v3"/></svg>
          <span>كل يوم جمعة</span>
        </div>
        <div class="match-row">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/></svg>
          <span>من 8:00 م لـ 10:00 م</span>
        </div>
        <div class="match-row" style="margin-bottom:0">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"><path d="M12 21s-7-5.2-7-11a7 7 0 0 1 14 0c0 5.8-7 11-7 11z"/><circle cx="12" cy="10" r="2.5"/></svg>
          <span>التجمع الخامس، القاهرة</span>
        </div>
      </section>

      <!-- Rules -->
      <section class="glass-card" style="margin-bottom:var(--s-md)">
        <h3 class="section-title" style="font-size:17px;margin-bottom:var(--s-md)">نظام الدوري</h3>
        <ul class="bullet-list">
          <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 6 9 17l-5-5"/></svg> كل فريق يلعب ضد باقي الفرق ذهاب وإياب.</li>
          <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 6 9 17l-5-5"/></svg> الفوز = 3 نقط، التعادل = 1، الخسارة = 0.</li>
          <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 6 9 17l-5-5"/></svg> الفريق الأول يفوز بجائزة نقدية.</li>
          <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 6 9 17l-5-5"/></svg> ممنوع التدخيل العنيف خالص.</li>
        </ul>
      </section>

      <!-- Joined teams -->
      <section class="glass-card" style="margin-bottom:var(--s-md)">
        <div class="section-head" style="margin:0 0 var(--s-md)">
          <h3 class="section-title" style="font-size:17px">الفرق المنضمة</h3>
          <span class="pill pill--neutral">4 فرق</span>
        </div>

        <a href="/team-details" class="team-card">
          <span class="team-card__icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75"/></svg>
          </span>
          <div class="team-card__info">
            <div class="team-card__name">الصقور</div>
            <div class="team-card__sub">5 لاعبين · الكابتن: أحمد علي</div>
          </div>
          <span class="team-card__chev"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="m13 18-6-6 6-6"/></svg></span>
        </a>

        <a href="/team-details" class="team-card">
          <span class="team-card__icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75"/></svg>
          </span>
          <div class="team-card__info">
            <div class="team-card__name">النسور</div>
            <div class="team-card__sub">4 لاعبين · الكابتن: عمر خالد</div>
          </div>
          <span class="team-card__chev"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="m13 18-6-6 6-6"/></svg></span>
        </a>

        <a href="/team-details" class="team-card">
          <span class="team-card__icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75"/></svg>
          </span>
          <div class="team-card__info">
            <div class="team-card__name">الأبطال</div>
            <div class="team-card__sub">5 لاعبين · الكابتن: محمود حسن</div>
          </div>
          <span class="team-card__chev"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="m13 18-6-6 6-6"/></svg></span>
        </a>

        <a href="/team-details" class="team-card">
          <span class="team-card__icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75"/></svg>
          </span>
          <div class="team-card__info">
            <div class="team-card__name">الفرسان</div>
            <div class="team-card__sub">3 لاعبين · الكابتن: كريم سامي</div>
          </div>
          <span class="team-card__chev"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="m13 18-6-6 6-6"/></svg></span>
        </a>
      </section>

      <div class="divider-text">أو</div>

    </main>

    <!-- Sticky CTA pair -->
    <div class="sticky-cta">
      <div class="cta-pair">
        <a href="/team-details" class="btn-pitch--outline btn-pitch--sm">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75"/></svg>
          انضمام لفريق
        </a>
        <a href="/create-team" class="btn-pitch btn-pitch--sm" style="display:flex;align-items:center;justify-content:center;gap:6px;text-decoration:none">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" style="width:18px;height:18px"><path d="M12 5v14M5 12h14"/></svg>
          إنشاء فريق
        </a>
      </div>
    </div>

  </div>
