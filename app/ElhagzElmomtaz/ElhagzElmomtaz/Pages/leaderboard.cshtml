@page
@model LeaderboardModel
@{
    ViewData["Title"] = "الإحصائيات — الحجز الممتاز";
}
  <div class="app-page">

    <header class="app-bar">
      <h1 class="app-bar__title">الإحصائيات</h1>
      <a href="#" class="icon-btn" aria-label="الإشعارات">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8a6 6 0 0 0-12 0c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.7 21a2 2 0 0 1-3.4 0"/></svg>
      </a>
    </header>

    <main class="app-content">

      <!-- Period toggle -->
      <div class="toggle-pills">
        <input type="radio" name="period" id="p-month" checked />
        <label for="p-month">الشهر ده</label>
        <input type="radio" name="period" id="p-season" />
        <label for="p-season">الموسم</label>
      </div>

      <!-- Podium -->
      <div class="podium">
        <div class="podium__item podium__item--3">
          <span class="ring ring-bronze"><span class="avatar avatar--lg"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 12a5 5 0 1 0 0-10 5 5 0 0 0 0 10zm0 2c-5 0-9 2.5-9 6v1h18v-1c0-3.5-4-6-9-6z"/></svg></span></span>
          <div class="podium__rank podium__rank--3">3</div>
          <div class="podium__name">محمود حسن</div>
          <div class="podium__pts">129</div>
        </div>
        <div class="podium__item podium__item--1">
          <span class="ring ring-gold"><span class="avatar avatar--xl"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 12a5 5 0 1 0 0-10 5 5 0 0 0 0 10zm0 2c-5 0-9 2.5-9 6v1h18v-1c0-3.5-4-6-9-6z"/></svg></span></span>
          <div class="podium__rank podium__rank--1">1</div>
          <div class="podium__name">أحمد علي</div>
          <div class="podium__pts">158</div>
        </div>
        <div class="podium__item podium__item--2">
          <span class="ring ring-silver"><span class="avatar avatar--lg"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 12a5 5 0 1 0 0-10 5 5 0 0 0 0 10zm0 2c-5 0-9 2.5-9 6v1h18v-1c0-3.5-4-6-9-6z"/></svg></span></span>
          <div class="podium__rank podium__rank--2">2</div>
          <div class="podium__name">عمر خالد</div>
          <div class="podium__pts">142</div>
        </div>
      </div>

      <!-- Points explainer -->
      <div class="info-note">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="12" cy="12" r="9"/><path d="M12 8h.01M11 12h1v4h1"/></svg>
        <div>
          <p class="info-note__title">إزاي النقط بتتحسب؟</p>
          <p class="info-note__text">فوز = 3، تعادل = 1، خسارة = 0 · نقطة لكل جون، + نقطة لكل أسيست.</p>
        </div>
      </div>

      <!-- Full table -->
      <div class="data-card">
        <table class="data-table">
          <thead>
            <tr><th>النقط</th><th>س</th><th>أ</th><th>ف/خ/ت</th><th>ل</th><th>اللعيب</th><th>م</th></tr>
          </thead>
          <tbody>
            <tr>
              <td class="t-points">142</td><td>12</td><td>11</td><td>7/3/2</td><td>12</td>
              <td><span class="cell-player"><span class="avatar" style="width:28px;height:28px"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 12a5 5 0 1 0 0-10 5 5 0 0 0 0 10zm0 2c-5 0-9 2.5-9 6v1h18v-1c0-3.5-4-6-9-6z"/></svg></span> عمر خ.</span></td>
              <td class="col-strong">2</td>
            </tr>
            <tr>
              <td class="t-points">129</td><td>8</td><td>10</td><td>6/4/1</td><td>11</td>
              <td><span class="cell-player"><span class="avatar" style="width:28px;height:28px"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 12a5 5 0 1 0 0-10 5 5 0 0 0 0 10zm0 2c-5 0-9 2.5-9 6v1h18v-1c0-3.5-4-6-9-6z"/></svg></span> محمود ح.</span></td>
              <td class="col-strong">3</td>
            </tr>
            <tr>
              <td class="t-points">114</td><td>6</td><td>8</td><td>5/5/2</td><td>12</td>
              <td><span class="cell-player"><span class="avatar" style="width:28px;height:28px"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 12a5 5 0 1 0 0-10 5 5 0 0 0 0 10zm0 2c-5 0-9 2.5-9 6v1h18v-1c0-3.5-4-6-9-6z"/></svg></span> سامح ع.</span></td>
              <td class="col-strong">4</td>
            </tr>
            <tr>
              <td class="t-points">98</td><td>4</td><td>6</td><td>4/4/2</td><td>10</td>
              <td><span class="cell-player"><span class="avatar" style="width:28px;height:28px"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 12a5 5 0 1 0 0-10 5 5 0 0 0 0 10zm0 2c-5 0-9 2.5-9 6v1h18v-1c0-3.5-4-6-9-6z"/></svg></span> خالد س.</span></td>
              <td class="col-strong">5</td>
            </tr>
            <tr>
              <td class="t-points">82</td><td>5</td><td>4</td><td>3/3/3</td><td>9</td>
              <td><span class="cell-player"><span class="avatar" style="width:28px;height:28px"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 12a5 5 0 1 0 0-10 5 5 0 0 0 0 10zm0 2c-5 0-9 2.5-9 6v1h18v-1c0-3.5-4-6-9-6z"/></svg></span> عادل م.</span></td>
              <td class="col-strong">6</td>
            </tr>
          </tbody>
        </table>
      </div>
    </main>

    <nav class="tab-bar">
      <a href="/matches" class="tab-bar__item is-active">
        <i class="fa-solid fa-futbol"></i>
        ماتشات
      </a>
      <a href="/leagues" class="tab-bar__item">
        <i class="fa-solid fa-ranking-star"></i>
        دوريات
      </a>
      <a href="/tournaments" class="tab-bar__item">
        <i class="fa-solid fa-trophy"></i>
        بطولات
      </a>
      <a href="/profile" class="tab-bar__item">
        <i class="fa-solid fa-user"></i>
        حسابي
      </a>
    </nav>

  </div>
