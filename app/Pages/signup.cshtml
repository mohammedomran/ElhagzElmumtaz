@page
@model SignupModel
@{
    ViewData["Title"] = "اعمل حساب — الحجز الممتاز";
}
  <main class="auth-shell">
    <div class="auth-wrap">

      <!-- Brand -->
      <header class="brand">
        <span class="brand-logo" aria-hidden="true">
          <img src="/assets/logo.png" alt="logo" height="100" />
        </span>
        <p class="brand-subtitle">اعمل حساب</p>
      </header>

      <!-- Card -->
      <section class="glass-card">
        <form novalidate>

          <!-- Avatar uploader -->
          <div class="avatar-upload">
            <label class="avatar-ring" for="avatar">
              <img id="avatar-preview" alt="" hidden />
              <span id="avatar-placeholder" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"
                  stroke-linejoin="round">
                  <path
                    d="M14.5 4h-5L8 6H4a2 2 0 0 0-2 2v10a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V8a2 2 0 0 0-2-2h-4l-1.5-2z" />
                  <circle cx="12" cy="13" r="3.5" />
                </svg>
              </span>
              <span class="avatar-edit" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"
                  stroke-linejoin="round">
                  <path d="M12 20h9" />
                  <path d="M16.5 3.5a2.12 2.12 0 0 1 3 3L7 19l-4 1 1-4 12.5-12.5z" />
                </svg>
              </span>
              <input id="avatar" type="file" accept="image/*" hidden />
            </label>
            <span class="avatar-hint">صورتك يا بطل</span>
          </div>

          <!-- Full name -->
          <div class="field">
            <label class="field-label" for="name">الاسم بالكامل</label>
            <div class="input-shell">
              <input id="name" type="text" placeholder="مثلاً: أحمد محمد" autocomplete="name" />
            </div>
          </div>

          <!-- Email -->
          <div class="field">
            <label class="field-label" for="email">الإيميل</label>
            <div class="input-shell">
              <input id="email" type="email" inputmode="email" placeholder="name@example.com" autocomplete="email" />
            </div>
          </div>

          <!-- Phone -->
          <div class="field">
            <label class="field-label" for="phone">رقم الموبايل</label>
            <div class="input-shell">
              <span class="input-prefix">20+</span>
              <input id="phone" type="tel" inputmode="tel" placeholder="102 345 6789" autocomplete="tel" />
            </div>
          </div>

          <!-- Birth date -->
          <div class="field">
            <label class="field-label" for="dob">تاريخ ميلادك</label>
            <div class="input-shell">
              <input id="dob" type="date" />
              <span class="input-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"
                  stroke-linejoin="round">
                  <rect x="3" y="4.5" width="18" height="16" rx="2" />
                  <path d="M3 9h18M8 3v3M16 3v3" />
                </svg>
              </span>
            </div>
          </div>

          <!-- Skill level -->
          <div class="field">
            <label class="field-label">مستواك</label>
            <div class="segment">
              <input type="radio" name="level" id="lvl-1" checked />
              <label for="lvl-1">مبتدئ</label>
              <input type="radio" name="level" id="lvl-2" />
              <label for="lvl-2">متوسط</label>
              <input type="radio" name="level" id="lvl-3" />
              <label for="lvl-3">محترف</label>
            </div>
          </div>

          <!-- Password -->
          <div class="field">
            <label class="field-label" for="password">كلمة السر</label>
            <div class="input-shell">
              <input id="password" type="password" placeholder="••••••••" autocomplete="new-password" />
              <button type="button" class="input-icon" data-toggle-password="password" aria-label="إظهار كلمة السر">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"
                  stroke-linejoin="round">
                  <path d="M2 12s3.5-7 10-7 10 7 10 7-3.5 7-10 7-10-7-10-7z" />
                  <circle cx="12" cy="12" r="3" />
                </svg>
              </button>
            </div>
          </div>

          <!-- Confirm password -->
          <div class="field">
            <label class="field-label" for="password2">تأكيد كلمة السر</label>
            <div class="input-shell">
              <input id="password2" type="password" placeholder="••••••••" autocomplete="new-password" />
              <button type="button" class="input-icon" data-toggle-password="password2" aria-label="إظهار كلمة السر">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"
                  stroke-linejoin="round">
                  <path d="M2 12s3.5-7 10-7 10 7 10 7-3.5 7-10 7-10-7-10-7z" />
                  <circle cx="12" cy="12" r="3" />
                </svg>
              </button>
            </div>
          </div>

          <div class="divider-space"></div>
          <button type="submit" class="btn-pitch">إنشاء حساب</button>
        </form>
      </section>

      <!-- Footer -->
      <p class="auth-footer">
        عندك حساب أصلاً؟ <a href="/signin">سجل دخول</a>
      </p>

    </div>
  </main>

  <script>
    // Password visibility toggles
    document.querySelectorAll("[data-toggle-password]").forEach(function (btn) {
      btn.addEventListener("click", function () {
        var input = document.getElementById(btn.dataset.togglePassword);
        if (!input) return;
        var show = input.type === "password";
        input.type = show ? "text" : "password";
        btn.setAttribute("aria-label", show ? "إخفاء كلمة السر" : "إظهار كلمة السر");
      });
    });

    // Avatar preview
    var avatarInput = document.getElementById("avatar");
    avatarInput.addEventListener("change", function () {
      var file = this.files && this.files[0];
      if (!file) return;
      var img = document.getElementById("avatar-preview");
      var ph = document.getElementById("avatar-placeholder");
      img.src = URL.createObjectURL(file);
      img.hidden = false;
      ph.style.display = "none";
    });
  </script>
