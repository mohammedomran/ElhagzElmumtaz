@page
@model EditProfileModel
@{
    ViewData["Title"] = "تعديل الملف — الحجز الممتاز";
}
  <div class="app-page">

    <header class="app-bar">
      <h1 class="app-bar__title">تعديل الملف</h1>
      <a href="/profile" class="app-bar__back">
        رجوع
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
      </a>
    </header>

    <main class="app-content">
      <form novalidate>

        <!-- Avatar -->
        <div class="avatar-upload">
          <label class="avatar-ring" for="avatar" style="width:120px;height:120px;border-style:solid;border-color:var(--primary)">
            <img id="avatar-preview" alt="" hidden />
            <span id="avatar-placeholder" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 12a5 5 0 1 0 0-10 5 5 0 0 0 0 10zm0 2c-5 0-9 2.5-9 6v1h18v-1c0-3.5-4-6-9-6z"/></svg>
            </span>
            <span class="avatar-edit" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M14.5 4h-5L8 6H4a2 2 0 0 0-2 2v10a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V8a2 2 0 0 0-2-2h-4l-1.5-2z"/><circle cx="12" cy="13" r="3.5"/></svg>
            </span>
            <input id="avatar" type="file" accept="image/*" hidden />
          </label>
          <span class="link-primary-soft" style="cursor:pointer">غير صورتك</span>
        </div>

        <div class="field">
          <label class="field-label" for="name">اسمك</label>
          <div class="input-shell"><input id="name" type="text" value="أحمد محمد" /></div>
        </div>

        <div class="field">
          <label class="field-label" for="nick">اسم الشهرة</label>
          <div class="input-shell"><input id="nick" type="text" placeholder="@@برنس_الملاعب" /></div>
        </div>

        <div class="field">
          <label class="field-label" for="dob">تاريخ الميلاد</label>
          <div class="input-shell">
            <input id="dob" type="date" />
            <span class="input-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"><rect x="3" y="4.5" width="18" height="16" rx="2"/><path d="M3 9h18M8 3v3M16 3v3"/></svg>
            </span>
          </div>
        </div>

        <div class="field">
          <label class="field-label">مستواك</label>
          <div class="segment">
            <input type="radio" name="level" id="lvl-1" />
            <label for="lvl-1">مبتدئ</label>
            <input type="radio" name="level" id="lvl-2" checked />
            <label for="lvl-2">متوسط</label>
            <input type="radio" name="level" id="lvl-3" />
            <label for="lvl-3">محترف</label>
          </div>
        </div>
      </form>
    </main>

    <div class="sticky-cta">
      <button class="btn-pitch" style="display:flex;align-items:center;justify-content:center;gap:8px">
        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="9"/><path d="m8 12 3 3 5-6"/></svg>
        حفظ التعديلات
      </button>
    </div>

  </div>

  <script>
    var avatarInput = document.getElementById("avatar");
    avatarInput.addEventListener("change", function () {
      var file = this.files && this.files[0];
      if (!file) return;
      var img = document.getElementById("avatar-preview");
      var ph = document.getElementById("avatar-placeholder");
      img.src = URL.createObjectURL(file);
      img.hidden = false;
      ph.style.display = "none";
    });
  </script>
