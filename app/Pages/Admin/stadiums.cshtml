@page
@model ElhagzElmomtaz.Pages.Admin.StadiumsModel
@{
    ViewData["Title"] = "Stadiums";
    Layout = "_AdminLayout";
}

<div class="card">
  <div class="card-body">
    <div class="d-sm-flex d-block align-items-center justify-content-between mb-4">
      <h5 class="card-title fw-semibold mb-0">Stadiums</h5>
      <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#addStadiumModal">
        <i class="ti ti-plus"></i> Add Stadium
      </button>
    </div>

    <div class="table-responsive">
      <table class="table text-nowrap mb-0 align-middle">
        <thead class="text-dark fs-4">
          <tr>
            <th class="border-bottom-0"><h6 class="fw-semibold mb-0">#</h6></th>
            <th class="border-bottom-0"><h6 class="fw-semibold mb-0">Name</h6></th>
            <th class="border-bottom-0"><h6 class="fw-semibold mb-0">City</h6></th>
            <th class="border-bottom-0"><h6 class="fw-semibold mb-0">Address</h6></th>
            <th class="border-bottom-0"><h6 class="fw-semibold mb-0">Map</h6></th>
            <th class="border-bottom-0 text-end"><h6 class="fw-semibold mb-0">Actions</h6></th>
          </tr>
        </thead>
        <tbody>
          @{ var i = 0; }
          @foreach (var s in Model.Stadiums)
          {
            i++;
            <tr>
              <td class="border-bottom-0"><h6 class="fw-semibold mb-0">@i</h6></td>
              <td class="border-bottom-0"><h6 class="fw-semibold mb-0">@s.Name</h6></td>
              <td class="border-bottom-0"><p class="mb-0 fw-normal">@s.City</p></td>
              <td class="border-bottom-0"><p class="mb-0 fw-normal">@s.Address</p></td>
              <td class="border-bottom-0">
                <a href="@s.MapsUrl" target="_blank" class="text-primary fw-semibold">
                  <i class="ti ti-map-pin"></i> View
                </a>
              </td>
              <td class="border-bottom-0 text-end">
                <button type="button" class="btn btn-sm btn-light-primary text-primary"
                        data-bs-toggle="modal" data-bs-target="#editStadiumModal"
                        data-id="@s.Id" data-name="@s.Name" data-city="@s.City"
                        data-address="@s.Address" data-maps="@s.MapsUrl">
                  <i class="ti ti-edit"></i> Edit
                </button>
                <button type="button" class="btn btn-sm btn-light-danger text-danger"
                        data-bs-toggle="modal" data-bs-target="#deleteStadiumModal"
                        data-name="@s.Name">
                  <i class="ti ti-trash"></i> Delete
                </button>
              </td>
            </tr>
          }
        </tbody>
      </table>
    </div>
  </div>
</div>

<!-- Add modal -->
<div class="modal fade" id="addStadiumModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title">Add Stadium</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        <div class="mb-3">
          <label class="form-label">Name</label>
          <input type="text" class="form-control" placeholder="Stadium name">
        </div>
        <div class="mb-3">
          <label class="form-label">City</label>
          <select class="form-select">
            <option selected disabled>Choose a city</option>
            @foreach (var city in Model.Cities)
            {
              <option>@city</option>
            }
          </select>
        </div>
        <div class="mb-3">
          <label class="form-label">Address</label>
          <input type="text" class="form-control" placeholder="Street address">
        </div>
        <div class="mb-3">
          <label class="form-label">Google Maps URL</label>
          <input type="url" class="form-control" placeholder="https://maps.google.com/...">
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancel</button>
        <button type="button" class="btn btn-primary" data-bs-dismiss="modal">Save</button>
      </div>
    </div>
  </div>
</div>

<!-- Edit modal -->
<div class="modal fade" id="editStadiumModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title">Edit Stadium</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        <div class="mb-3">
          <label class="form-label">Name</label>
          <input type="text" class="form-control edit-name">
        </div>
        <div class="mb-3">
          <label class="form-label">City</label>
          <select class="form-select edit-city">
            @foreach (var city in Model.Cities)
            {
              <option>@city</option>
            }
          </select>
        </div>
        <div class="mb-3">
          <label class="form-label">Address</label>
          <input type="text" class="form-control edit-address">
        </div>
        <div class="mb-3">
          <label class="form-label">Google Maps URL</label>
          <input type="url" class="form-control edit-maps">
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancel</button>
        <button type="button" class="btn btn-primary" data-bs-dismiss="modal">Save</button>
      </div>
    </div>
  </div>
</div>

<!-- Delete modal -->
<div class="modal fade" id="deleteStadiumModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title">Delete Stadium</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        Are you sure you want to delete <strong class="delete-name"></strong>?
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancel</button>
        <button type="button" class="btn btn-danger" data-bs-dismiss="modal">Delete</button>
      </div>
    </div>
  </div>
</div>

@section Scripts {
  <script>
    (function () {
      var editModal = document.getElementById('editStadiumModal');
      editModal.addEventListener('show.bs.modal', function (e) {
        var b = e.relatedTarget;
        editModal.querySelector('.edit-name').value = b.getAttribute('data-name');
        editModal.querySelector('.edit-city').value = b.getAttribute('data-city');
        editModal.querySelector('.edit-address').value = b.getAttribute('data-address');
        editModal.querySelector('.edit-maps').value = b.getAttribute('data-maps');
      });
      var delModal = document.getElementById('deleteStadiumModal');
      delModal.addEventListener('show.bs.modal', function (e) {
        delModal.querySelector('.delete-name').textContent = e.relatedTarget.getAttribute('data-name');
      });
    })();
  </script>
}
