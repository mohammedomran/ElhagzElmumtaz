@page
@model ElhagzElmomtaz.Pages.Admin.CitiesModel
@{
    ViewData["Title"] = "Cities";
    Layout = "_AdminLayout";
}

<div class="card">
  <div class="card-body">
    <div class="d-sm-flex d-block align-items-center justify-content-between mb-4">
      <h5 class="card-title fw-semibold mb-0">Cities</h5>
      <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#addCityModal">
        <i class="ti ti-plus"></i> Add City
      </button>
    </div>

    <div class="table-responsive">
      <table class="table text-nowrap mb-0 align-middle">
        <thead class="text-dark fs-4">
          <tr>
            <th class="border-bottom-0"><h6 class="fw-semibold mb-0">#</h6></th>
            <th class="border-bottom-0"><h6 class="fw-semibold mb-0">Name</h6></th>
            <th class="border-bottom-0"><h6 class="fw-semibold mb-0">Created</h6></th>
            <th class="border-bottom-0 text-end"><h6 class="fw-semibold mb-0">Actions</h6></th>
          </tr>
        </thead>
        <tbody>
          @{ var i = 0; }
          @foreach (var c in Model.Cities)
          {
            i++;
            <tr>
              <td class="border-bottom-0"><h6 class="fw-semibold mb-0">@i</h6></td>
              <td class="border-bottom-0"><h6 class="fw-semibold mb-0">@c.Name</h6></td>
              <td class="border-bottom-0"><p class="mb-0 fw-normal">@c.CreatedAt</p></td>
              <td class="border-bottom-0 text-end">
                <button type="button" class="btn btn-sm btn-light-primary text-primary"
                        data-bs-toggle="modal" data-bs-target="#editCityModal"
                        data-id="@c.Id" data-name="@c.Name">
                  <i class="ti ti-edit"></i> Edit
                </button>
                <button type="button" class="btn btn-sm btn-light-danger text-danger"
                        data-bs-toggle="modal" data-bs-target="#deleteCityModal"
                        data-name="@c.Name">
                  <i class="ti ti-trash"></i> Delete
                </button>
              </td>
            </tr>
          }
        </tbody>
      </table>
    </div>
  </div>
</div>

<!-- Add modal -->
<div class="modal fade" id="addCityModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title">Add City</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        <div class="mb-3">
          <label class="form-label">Name</label>
          <input type="text" class="form-control" placeholder="City name">
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancel</button>
        <button type="button" class="btn btn-primary" data-bs-dismiss="modal">Save</button>
      </div>
    </div>
  </div>
</div>

<!-- Edit modal -->
<div class="modal fade" id="editCityModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title">Edit City</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        <div class="mb-3">
          <label class="form-label">Name</label>
          <input type="text" class="form-control edit-name">
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancel</button>
        <button type="button" class="btn btn-primary" data-bs-dismiss="modal">Save</button>
      </div>
    </div>
  </div>
</div>

<!-- Delete modal -->
<div class="modal fade" id="deleteCityModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title">Delete City</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        Are you sure you want to delete <strong class="delete-name"></strong>?
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancel</button>
        <button type="button" class="btn btn-danger" data-bs-dismiss="modal">Delete</button>
      </div>
    </div>
  </div>
</div>

@section Scripts {
  <script>
    (function () {
      var editModal = document.getElementById('editCityModal');
      editModal.addEventListener('show.bs.modal', function (e) {
        var btn = e.relatedTarget;
        editModal.querySelector('.edit-name').value = btn.getAttribute('data-name');
      });
      var delModal = document.getElementById('deleteCityModal');
      delModal.addEventListener('show.bs.modal', function (e) {
        delModal.querySelector('.delete-name').textContent = e.relatedTarget.getAttribute('data-name');
      });
    })();
  </script>
}
