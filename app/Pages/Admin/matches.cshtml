@page
@model ElhagzElmomtaz.Pages.Admin.MatchesModel
@{
    ViewData["Title"] = "Friendly Matches";
    Layout = "_AdminLayout";
}

<div class="card">
  <div class="card-body">
    <div class="d-sm-flex d-block align-items-center justify-content-between mb-4">
      <h5 class="card-title fw-semibold mb-0">Friendly Matches</h5>
      <a href="/Admin/match-create" class="btn btn-primary">
        <i class="ti ti-plus"></i> Add Match
      </a>
    </div>

    <div class="table-responsive">
      <table class="table text-nowrap mb-0 align-middle">
        <thead class="text-dark fs-4">
          <tr>
            <th class="border-bottom-0"><h6 class="fw-semibold mb-0">#</h6></th>
            <th class="border-bottom-0"><h6 class="fw-semibold mb-0">Stadium</h6></th>
            <th class="border-bottom-0"><h6 class="fw-semibold mb-0">Date</h6></th>
            <th class="border-bottom-0"><h6 class="fw-semibold mb-0">From</h6></th>
            <th class="border-bottom-0"><h6 class="fw-semibold mb-0">To</h6></th>
            <th class="border-bottom-0 text-end"><h6 class="fw-semibold mb-0">Actions</h6></th>
          </tr>
        </thead>
        <tbody>
          @{ var i = 0; }
          @foreach (var m in Model.Matches)
          {
            i++;
            <tr>
              <td class="border-bottom-0"><h6 class="fw-semibold mb-0">@i</h6></td>
              <td class="border-bottom-0"><h6 class="fw-semibold mb-0">@m.Stadium</h6></td>
              <td class="border-bottom-0"><p class="mb-0 fw-normal">@m.ScheduledDate</p></td>
              <td class="border-bottom-0"><p class="mb-0 fw-normal">@m.FromTime</p></td>
              <td class="border-bottom-0"><p class="mb-0 fw-normal">@m.ToTime</p></td>
              <td class="border-bottom-0 text-end">
                <a href="/Admin/match-edit?id=@m.Id" class="btn btn-sm btn-light-primary text-primary">
                  <i class="ti ti-edit"></i> Edit
                </a>
                <button type="button" class="btn btn-sm btn-light-danger text-danger"
                        data-bs-toggle="modal" data-bs-target="#deleteMatchModal"
                        data-name="@m.Stadium — @m.ScheduledDate">
                  <i class="ti ti-trash"></i> Delete
                </button>
              </td>
            </tr>
          }
        </tbody>
      </table>
    </div>
  </div>
</div>

<!-- Delete modal -->
<div class="modal fade" id="deleteMatchModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title">Delete Match</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        Are you sure you want to delete the match <strong class="delete-name"></strong>?
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancel</button>
        <button type="button" class="btn btn-danger" data-bs-dismiss="modal">Delete</button>
      </div>
    </div>
  </div>
</div>

@section Scripts {
  <script>
    (function () {
      var delModal = document.getElementById('deleteMatchModal');
      delModal.addEventListener('show.bs.modal', function (e) {
        delModal.querySelector('.delete-name').textContent = e.relatedTarget.getAttribute('data-name');
      });
    })();
  </script>
}
