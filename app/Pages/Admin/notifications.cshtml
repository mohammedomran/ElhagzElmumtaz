@page
@model ElhagzElmomtaz.Pages.Admin.NotificationsModel
@{
    ViewData["Title"] = "Notifications";
    Layout = "_AdminLayout";
}

<div class="card">
  <div class="card-body">
    <div class="d-sm-flex d-block align-items-center justify-content-between mb-4">
      <h5 class="card-title fw-semibold mb-0">Notifications</h5>
      <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#addNotificationModal">
        <i class="ti ti-plus"></i> Add Notification
      </button>
    </div>

    <div class="table-responsive">
      <table class="table text-nowrap mb-0 align-middle">
        <thead class="text-dark fs-4">
          <tr>
            <th class="border-bottom-0"><h6 class="fw-semibold mb-0">#</h6></th>
            <th class="border-bottom-0"><h6 class="fw-semibold mb-0">Title</h6></th>
            <th class="border-bottom-0"><h6 class="fw-semibold mb-0">Body</h6></th>
            <th class="border-bottom-0"><h6 class="fw-semibold mb-0">Created</h6></th>
            <th class="border-bottom-0 text-end"><h6 class="fw-semibold mb-0">Actions</h6></th>
          </tr>
        </thead>
        <tbody>
          @{ var i = 0; }
          @foreach (var n in Model.Notifications)
          {
            i++;
            <tr>
              <td class="border-bottom-0"><h6 class="fw-semibold mb-0">@i</h6></td>
              <td class="border-bottom-0"><h6 class="fw-semibold mb-0">@n.Title</h6></td>
              <td class="border-bottom-0"><p class="mb-0 fw-normal text-truncate" style="max-width:320px">@n.Body</p></td>
              <td class="border-bottom-0"><p class="mb-0 fw-normal">@n.CreatedAt</p></td>
              <td class="border-bottom-0 text-end">
                <button type="button" class="btn btn-sm btn-light-primary text-primary"
                        data-bs-toggle="modal" data-bs-target="#editNotificationModal"
                        data-id="@n.Id" data-title="@n.Title" data-body="@n.Body">
                  <i class="ti ti-edit"></i> Edit
                </button>
                <button type="button" class="btn btn-sm btn-light-danger text-danger"
                        data-bs-toggle="modal" data-bs-target="#deleteNotificationModal"
                        data-name="@n.Title">
                  <i class="ti ti-trash"></i> Delete
                </button>
              </td>
            </tr>
          }
        </tbody>
      </table>
    </div>
  </div>
</div>

<!-- Add modal -->
<div class="modal fade" id="addNotificationModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title">Add Notification</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        <div class="mb-3">
          <label class="form-label">Title</label>
          <input type="text" class="form-control" placeholder="Notification title">
        </div>
        <div class="mb-3">
          <label class="form-label">Body</label>
          <textarea class="form-control" rows="4" placeholder="Notification body"></textarea>
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancel</button>
        <button type="button" class="btn btn-primary" data-bs-dismiss="modal">Save</button>
      </div>
    </div>
  </div>
</div>

<!-- Edit modal -->
<div class="modal fade" id="editNotificationModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title">Edit Notification</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        <div class="mb-3">
          <label class="form-label">Title</label>
          <input type="text" class="form-control edit-title">
        </div>
        <div class="mb-3">
          <label class="form-label">Body</label>
          <textarea class="form-control edit-body" rows="4"></textarea>
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancel</button>
        <button type="button" class="btn btn-primary" data-bs-dismiss="modal">Save</button>
      </div>
    </div>
  </div>
</div>

<!-- Delete modal -->
<div class="modal fade" id="deleteNotificationModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title">Delete Notification</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        Are you sure you want to delete <strong class="delete-name"></strong>?
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancel</button>
        <button type="button" class="btn btn-danger" data-bs-dismiss="modal">Delete</button>
      </div>
    </div>
  </div>
</div>

@section Scripts {
  <script>
    (function () {
      var editModal = document.getElementById('editNotificationModal');
      editModal.addEventListener('show.bs.modal', function (e) {
        var b = e.relatedTarget;
        editModal.querySelector('.edit-title').value = b.getAttribute('data-title');
        editModal.querySelector('.edit-body').value = b.getAttribute('data-body');
      });
      var delModal = document.getElementById('deleteNotificationModal');
      delModal.addEventListener('show.bs.modal', function (e) {
        delModal.querySelector('.delete-name').textContent = e.relatedTarget.getAttribute('data-name');
      });
    })();
  </script>
}
