@page
@model JoinRequestStatusModel
@{
    ViewData["Title"] = "طلب الانضمام — الحجز الممتاز";
}
  <div class="app-page">

    <header class="app-bar">
      <h1 class="app-bar__brand">الحجز الممتاز</h1>
      <a href="/leagues" class="icon-btn" aria-label="إغلاق">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><path d="M6 6l12 12M18 6 6 18"/></svg>
      </a>
    </header>

    <main class="app-content">
      <div class="status-wrap">

        <span class="status-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
            <path d="M6 2h12M6 22h12M6 2c0 5 4 6 6 8M18 2c0 5-4 6-6 8M6 22c0-5 4-6 6-8M18 22c0-5-4-6-6-8"/>
          </svg>
        </span>

        <span class="pill pill--accent pill--dot">تحت المراجعة</span>

        <h2 class="status-title">الطلب تحت مراجعة الكابتن</h2>

        <div class="status-detail">
          تم إرسال طلب الانضمام لفريق <strong>الصقور</strong> بنجاح.
          الكابتن <strong>أحمد علي</strong> هيراجع طلبك وهيبعتلك رد قريب.
          <div class="status-detail__row">
            <span>الفريق</span>
            <span class="status-detail__code">الصقور</span>
          </div>
          <div class="status-detail__row">
            <span>الدوري</span>
            <span class="status-detail__code">دوري الجمعة</span>
          </div>
        </div>

        <a href="#" class="btn-whatsapp">
          <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2a10 10 0 0 0-8.6 15l-1.4 5 5.1-1.3A10 10 0 1 0 12 2zm5.3 14.2c-.2.6-1.3 1.2-1.8 1.2-.5.1-1 .1-1.7-.1-.4-.1-.9-.3-1.6-.6-2.8-1.2-4.6-4-4.7-4.2-.1-.2-1.1-1.5-1.1-2.8s.7-2 .9-2.2c.2-.3.5-.3.7-.3h.5c.2 0 .4 0 .6.5l.8 1.9c.1.2.1.3 0 .5l-.4.6c-.1.2-.3.3-.1.6.1.2.6 1 1.4 1.7 1 .9 1.8 1.1 2 1.2.2.1.4.1.5-.1l.7-.8c.2-.2.3-.2.6-.1l1.9.9c.2.1.4.2.5.3.1.3.1.7-.1 1.3z"/></svg>
          تواصل مع الكابتن على واتساب
        </a>

        <p class="status-foot">هيتم إشعارك لما الكابتن يقبل أو يرفض الطلب</p>
      </div>
    </main>

  </div>
